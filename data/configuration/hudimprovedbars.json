{
  // Yes yes, I  do know what you're thinking... Adding comments to JSON is not standard compliant.
  // Forgive me, Todd Howard
  //====================================================================================================================
  // Improved Bars and HUD Configuration File
  // Created by DCHoaxer95 - https://www.nexusmods.com/fallout76/mods/3106
  // Version 1.17 only. Yes that means it won't work with older versions of the mod, and you cannot use older config
  // files with this version.
  // Last updated: Somewhere in February 2026
  // If you need help, visit the mod page or contact me on Nexus Mods or Discord
  // Oh and by the way, if you like this mod, consider endorsing it on Nexus Mods.
  // It helps a lot!
  // Enjoy!
  //====================================================================================================================
  // GENERAL SETTINGS
  //====================================================================================================================
  "features": [
    {
      // IHB language
      // Available values: "en" - English, "pl" - Polish, "de" - German, "fr" - French, "it" - Italian, "es" - Spanish,
      // "ru" - Russian, "zh" - Chinese
      // Sets the language for the mod. Does not affect game language.
      // Need more languages? Contact me on Nexus Mods or Discord
      "language": "en",
      // Global scale factor for all HUD elements. 1.0 is default size.  [Range: 0.1 - 10]
      // Use this setting to globally scale all HUD elements added by this mod.
      // If you want to scale individual elements, you can do that in the "widgets" section, by adding the
      // "scaleFactor" for desired widget.
      // This setting will scale all elements, including those that don't have individual scale settings.
      "scaleFactor": 0.9,
      // Should we automatically realign elements under the HP bar? [Available values: true/false]
      // This is needed for the widgets under the HP bar, such as weight, currencies, cores, clock,
      // because they have different widths, and if you have more than one of them enabled, they will overlap each
      // other.
      // DISABLE this if you have custom positions for these elements
      // When enabled, it will automatically align these elements to the left, on the X axis
      "autoAlignLeftGroup": true,
      // By default, the bars disappear after a short time when they reach [value]>=[thirstBarsPercentIndefiniteShow]%.
      // This can be useful for players who want to keep an eye on their hunger and thirst levels without worrying
      // about the bars disappearing.
      // For example, if you set this to 50, the bars will stay visible until your hunger or thirst increases above 50%.
      // Setting this to 100 makes it stay forever.  [Default game value: 0.2 Maximum value: 1.0]
      "thirstBarsPercentIndefiniteShow": 100,
      // Whether to show hunger and thirst icons next to the bars. [Available values: true/false]
      "showHungerThirstIcons": true,
      // Debug stuff
      // This section is for debugging purposes. It allows you to enable debug mode, which will show additional
      // information and messages in the console.
      // You can also enable messages for mod initialization and config reload events.
      // This can be useful for troubleshooting issues with the mod or for development purposes. [Available values:
      // true/false]
      // ShowDebug is not yet implemented. It will be implemented in the future, but for now, it does nothing.
      "debugSettings": {
        // Enable debug mode. do not use this
        "showDebug": false,
        // Show a message when mod is initialized
        "showModInitializationMessage": true,
        // Show a message when config is reloaded
        "showConfigReloadMessage": true
      },
      // This subsection defines specific widget settings, as well as the on-screen coordinates for the HUD elements.
      // All positions are relative to the parent containers. Change it only if you have to.
      // You can set the scale of each widget elements, if you do not like their default sizes.
      "widgets": [
        {
          // Experience widget shows your current level and experience progress. It can also show the percentage of experience progress towards the next level,
          // if you enable the percentage option.
          "xp": {
            "enabled": true,
            "percentage": true,
            "scaleFactor": 0.8,
            "x": -25,
            "y": -30
          },
          // Shows active effects and some other stuff. Experimental.
          // This widget REQUIRES SFE, in order to work. Due the way it handles some internal stuff, Incompatible with
          // save everything mod. Sorry!
          // Currently not implemented, but it will be in the future. For now, it does nothing.
          // NOT IMPLEMENTED
          "effectstracker": {
            "enabled": false,
            "x": -10,
            "y": -50,
            "showLunchboxes": true
          },
          // Vendor tracker shows when vendors are available to trade with you.
          // Currently supports Minerva vendor only.
          "vendortracker": {
            "enabled": false,
            // When enabled, shows minerva vendor status
            "minervaVendor": true,
            // Positioning
            "x": -550,
            "y": -75
          },
          // Nuke codes widget shows the actual nuke codes on the screen.
          "nukecodes": {
            // Whether to show nuke codes on the screen. [Available values: true/false]
            // Even if you disable this, you can still see the nuke codes by pressing F11 and going into Improved Bars
            // and HUD section. This setting only controls the visibility of the widget on the screen.
            "enabled": false,
            // POSITIONING
            "x": -585,
            "y": -20
          },
          "weight": {
            // Whether to display the player's current carry weight. [Available values: true/false]
            "enabled": true,
            // POSITIONING
            "x": -25,
            "y": -8
          },
          "currencies": {
            // Whether to show the number of bottle caps and optionally other currencies specified in "showOnly"
            // setting. [Available values: true/false]
            "enabled": true,
            // Which currencies to show, separated by ';' [Available values "caps", "bullion", "scrips", "stamps",
            // "tadpole", "possum", "supplies", "perks"]
            // You can change the order of currencies too. Type your desired order separated by ';'
            "showOnly": "caps;bullion;stamps;scrips;perks;tadpole;possum",
            // Should the icons be colored or mono?  [Available values: true/false]
            "coloredIcons": true,
            // POSITIONING
            // Whether to show icons vertically or horizontally [Available values: true/false]
            // autoAlignLeftGroup is disabled for this widget if this feature is enabled. Will mess up things, unless
            // you move each item individually.
            "vertical": true,
            "x": -90,
            "y": -80
          },
          "cores": {
            // Whether to display the number of fusion cores. [Available values: true/false]
            "enabled": true,
            // POSITIONING
            "x": 55,
            "y": -8
          },
          "clock": {
            // Displays a clock.
            // If you see the "not synced" message — open your Pip-Boy radio to sync the time.
            // If you're still seeing this message after opening pipboy's radio a few times - it means another mod is
            // conflicting with this feature.
            // It will de-sync if you minimize the game.
            "enabled": true,
            // Which clock to show, separated by ';'.  [Available values "server" - server time, "local" - local time.
            // Default is Server]
            "mode": "server;local",
            // Whether to show your local time next to the server time.
            "use24hFormat": true,
            // POSITIONING
            "x": 110,
            "y": -8
          },
          "weaponcond": {
            // Whether to show the condition of the currently equipped weapon. [Available values: true/false]
            "enabled": true,
            // You can enable weapon name display. If you disable this setting, you'll only see a percentage indicator,
            // e.g., (12.5%).
            "showNames": true,
            // By default, with weapon name display enabled, the widget shows the full name. You can use shortened
            // names to display only the weapon name itself, without legendaries.
            // It works only in some languages for now. Not in english.
            "shortenNames": false,
            // Toggles visibility of the weapon icon
            "showWeaponIcon": false,
            "x": 22,
            "y": -110
          },
          "stats": {
            // Whether to show the simple SPECIAL widget. [Available values: true/false]
            "enabled": true,
            // Whether to show icons vertically or horizontally [Available values: true/false, default: false]
            "vertical": false,
            "showDiffs": false,
            "x": 685,
            "y": 8
          },
          // Monitor up to 5 items. TEST ONLY
          // Pattern accepts a valid regex pattern.
          // Label is a text displayed on the screen
          // valuecolor, labelcolor are optional. they sets a color on counter and label fields
          // ===========================================================================================================
          // You need to create an appropriate regex rule for each item. I assume you know how to write regular
          // expressions. Visit https://regex101.com/ if you're looking for a testing tool.
          // If you're not familiar with this, unfortunately I don't have time to teach you. You can also use AI tools
          // like chatGPT to generate AS3 regex patterns with the parameters you want, and test it on the site above.
          // regex flags are always placed after the '/' sign. Eg "/Stimpak: Super/i" will match and count all
          // Super Stimpaks from your inventory. You can even create a regex that will
          // count only standard Stimpaks and Supers, and exclude Diluted.
          // ===========================================================================================================
          "itemmonitor": {
            "enabled": true,
            "inline": true,
            "x": -45,
            "y": 8,
            "valueprefix": "",
            "items": [
              {
                "enabled": true,
                "pattern": "/Stimpak/",
                "label": "Stimpaks",
                "valuecolor": "#66ACB7",
                "labelcolor": "#FFFFCA"
              },
              {
                "enabled": true,
                "pattern": "/Stimpak: Super/",
                "label": "Super Stimpaks",
                "valuecolor": "#66ACB7",
                "labelcolor": "#FFFFCA"
              },
              {
                "enabled": true,
                "pattern": "/Treasury Note/",
                "label": "Treasury Notes",
                "valuecolor": "#66ACB7",
                "labelcolor": "#FFFFCA"
              },
              {
                "enabled": true,
                "pattern": "/Wanted Poster/",
                "label": "Wanted Posters",
                "valuecolor": "#66ACB7",
                "labelcolor": "#FFFFCA"
              },
              {
                "enabled": true,
                "pattern": "/Technical Data/",
                "label": "Technical Data",
                "valuecolor": "#66ACB7",
                "labelcolor": "#FFFFCA"
              }
            ]
          }
        }
      ],
      "colors": [
        {
          "global": {
            "weight": "#FFFFAA",
            "currencies": {
              "caps": "#FFFFAA",
              "bullion": "#FFFFAA",
              "scrips": "#FFFFAA",
              "stamps": "#FFFFAA",
              "tadpole": "#FFFFAA",
              "possum": "#FFFFAA",
              "supplies": "#FFFFAA",
              "perks": "#FFFFAA",
              "maxValue": "#E63E30"
            },
            "cores": "#44EEFF",
            "clock": "#DDDDDD",
            "weaponcond": "#FFEEAA",
            "nukecodes": {
              "A": "#FFFFAA",
              "B": "#FFFFAA",
              "C": "#FFFFAA",
              "separator": "#FFFFAA",
              "value": "#66ACB7"
            },
            "special": {
              "S": "#779878",
              "P": "#786D4F",
              "E": "#66ACB7",
              "C": "#C58B4C",
              "I": "#9A9A80",
              "A": "#BD9079",
              "L": "#A19AAC"
            }
          }
        }
      ]
    }
  ],
  // ===================================================================================================================
  // SEGMENTS SETTINGS
  // This section allows you to configure segments for health, hunger, and thirst bars.
  // ===================================================================================================================
  "segments": [
    {
      // Enables segmented health bar. [Available values: true/false]
      "health": true,
      // Enables segmented hunger bar. [Available values: true/false]
      "hunger": true,
      // Enables segmented thirst bar. [Available values: true/false]
      "thirst": true,
      // Determines the style of the segments. Available styles:
      // health: "single" - single segment at 20% health, "full" - full segmented bar every 20% health
      // hunger: "single" - single segment at 20% hunger, "full" - full segmented bar every 20% hunger
      // thirst: "single" - single segment at 20% thirst, "full" - full segmented bar every 20% thirst
      "style": [
        {
          "health": "full",
          "hunger": "full",
          "thirst": "full"
        }
      ]
    }
  ],
  // ===================================================================================================================
  // PERCENTAGES SETTINGS
  // This section allows you to configure percentage displays for health, hunger, thirst, feral, and glow bars.
  // ===================================================================================================================
  "percentages": [
    {
      // Whether to show percentage  near health bar. [Available values: true/false]
      "health": true,
      // Whether to show the original bethesda's percentage near health bar. [Available values: true/false. Setting this
      // to true disables mods's health percentage info. if the percentage disappears completely, you have old HUDMenu
      // (ChatMod?)]
      "bethhealth": false,
      // Whether to show percentage  near hunger bar. [Available values: true/false]
      "hunger": false,
      // Whether to show percentage  near thirst bar. [Available values: true/false]
      "thirst": false,
      // Whether to show percentage  near feral bar. [Available values: true/false]
      "feral": true,
      //Whether to show percentage  near glow bar. [Available values: true/false]
      "glow": true,
      //Percentage postfix. Set it to "" to get rid of it
      "postfix": "%"
    }
  ]
}
